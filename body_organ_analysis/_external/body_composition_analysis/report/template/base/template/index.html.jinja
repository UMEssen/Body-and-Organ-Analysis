<!DOCTYPE html>
<html lang="en" {% if theme %}data-theme="{{ theme }}"{% endif %}>
  <head>
    <meta charset="UTF-8" />
    <title>{{ __app_title }}</title>
    <link href="style.css" rel="stylesheet" />
    {% block header %}{% endblock %}
  </head>

  <body>
    <footer id="footerAppInfo">
      <table>
        <tr>
          <td><b>App Version</b></td>
          <td>{{ app_version }}</td>
        </tr>
        <tr>
          <td><b>Contact</b></td>
          <td>{{ contact_email }}</td>
        </tr>
      </table>
    </footer>
    <header>
      <h1>{% block doc_title %}No Title{% endblock %}</h1>
    </header>
    {% block content %}{% endblock %}
  </body>
</html>
